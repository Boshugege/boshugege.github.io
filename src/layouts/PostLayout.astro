---
import { formatDate, normalizeTags, site } from "../lib/site";
import ThemeToggle from "../components/ThemeToggle.astro";
import DocumentLayout from "./DocumentLayout.astro";

interface Props {
  title: string;
  description?: string;
  date: Date | string;
  tags?: string[] | string;
  canonicalPath: string;
  image?: string;
  wordCount?: number;
  readingMinutes?: number;
  hasMath?: boolean;
  transitionKey?: string;
  previousPost?: { title: string; url: string };
  nextPost?: { title: string; url: string };
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = "",
  date,
  tags = [],
  canonicalPath,
  image = site.defaultCover,
  wordCount,
  readingMinutes,
  hasMath = false,
  transitionKey,
  previousPost,
  nextPost,
  jsonLd,
} = Astro.props;

const dateText = formatDate(date);
const tagList = normalizeTags(tags);
const excerpt = description || site.homeDescription;
const titleTransition = transitionKey ? `view-transition-name: post-title-${transitionKey};` : undefined;
const metaTransition = transitionKey ? `view-transition-name: post-meta-${transitionKey};` : undefined;
---

<DocumentLayout
  title={title}
  pageTitle={title}
  description={excerpt}
  canonicalPath={canonicalPath}
  ogType="article"
  image={image}
  includeKatex={hasMath}
  jsonLd={jsonLd}
  postMeta={{ title, date: dateText, tags: tagList, excerpt, cover: image, url: canonicalPath }}
>
  <ThemeToggle />
  <article class="post-content">
    <h1 style={titleTransition}>{title}</h1>
    <p class="meta" style={metaTransition}>
      {dateText}
      {typeof wordCount === "number" && ` · 约 ${wordCount.toLocaleString("zh-CN")} 字`}
      {typeof readingMinutes === "number" && ` · 约 ${readingMinutes} 分钟读完`}
      {tagList.length > 0 && " · 标签："}
      {tagList.map((tag, index) => (
        <>
          {index > 0 && ", "}
          <a href={`/index.html?tag=${encodeURIComponent(tag)}`}>{tag}</a>
        </>
      ))}
    </p>
    <div class="post-body" transition:name="post-body" transition:animate="fade">
      <slot />
      <nav class="post-nav" aria-label="文章导航">
        <div class="post-nav-item post-nav-prev">
          {previousPost && <a href={previousPost.url}>上一篇文章（{previousPost.title}）</a>}
        </div>
        <div class="post-nav-item post-nav-home">
          <a class="post-nav-link" href="/index.html" style="view-transition-name: post-nav-home;">返回首页</a>
        </div>
        <div class="post-nav-item post-nav-next">
          {nextPost && <a href={nextPost.url}>下一篇文章（{nextPost.title}）</a>}
        </div>
      </nav>
    </div>
  </article>
</DocumentLayout>
