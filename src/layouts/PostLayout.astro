---
import { formatDate, normalizeTags, site } from "../lib/site";
import ThemeToggle from "../components/ThemeToggle.astro";
import DocumentLayout from "./DocumentLayout.astro";
import "../styles/content.css";

interface Props {
  title: string;
  description?: string;
  date: Date | string;
  tags?: string[] | string;
  canonicalPath: string;
  image?: string;
  imageAlt?: string;
  updated?: Date | string;
  contentClass?: string;
  wordCount?: number;
  readingMinutes?: number;
  hasMath?: boolean;
  previousPost?: { title: string; url: string };
  nextPost?: { title: string; url: string };
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = "",
  date,
  tags = [],
  canonicalPath,
  image = site.defaultCover,
  imageAlt = site.defaultCoverAlt,
  updated,
  contentClass = "",
  wordCount,
  readingMinutes,
  hasMath = false,
  previousPost,
  nextPost,
  jsonLd,
} = Astro.props;

const dateText = formatDate(date);
const updatedText = updated ? formatDate(updated) : undefined;
const tagList = normalizeTags(tags);
const excerpt = description || site.homeDescription;
---

<DocumentLayout
  title={title}
  pageTitle={title}
  description={excerpt}
  canonicalPath={canonicalPath}
  ogType="article"
  image={image}
  imageAlt={imageAlt}
  includeKatex={hasMath}
  articlePublishedTime={dateText}
  articleModifiedTime={updatedText || dateText}
  jsonLd={jsonLd}
  postMeta={{ title, date: dateText, updated: updatedText, tags: tagList, excerpt, cover: image, coverAlt: imageAlt, url: canonicalPath }}
>
  <article class:list={["post-content", contentClass]}>
    <header class="post-topbar">
      <a class="site-title site-brand post-site-brand" href="/index.html" transition:name="site-brand">{site.name}</a>
      <nav class="post-topnav" aria-label="站点导航">
        <a href="/about.html">About</a>
        <a href="/notes.html">随想</a>
        <a href={`mailto:${site.email}`}>Email</a>
        <a href="/rss.xml">RSS</a>
        <a href={site.github}>GitHub</a>
      </nav>
      <ThemeToggle />
    </header>
    <h1>{title}</h1>
    <p class="meta">
      {dateText}
      {updatedText && updatedText !== dateText && ` · 更新：${updatedText}`}
      {typeof wordCount === "number" && ` · 约 ${wordCount.toLocaleString("zh-CN")} 字`}
      {typeof readingMinutes === "number" && ` · 约 ${readingMinutes} 分钟读完`}
      {tagList.length > 0 && " · 标签："}
      {tagList.map((tag, index) => (
        <>
          {index > 0 && ", "}
          <a href={`/index.html?tag=${encodeURIComponent(tag)}`}>{tag}</a>
        </>
      ))}
    </p>
    <div class="post-body">
      <slot />
      <nav class="post-nav" aria-label="文章导航">
        <div class="post-nav-item post-nav-prev">
          {previousPost && <a href={previousPost.url}>上一篇文章（{previousPost.title}）</a>}
        </div>
        <div class="post-nav-item post-nav-home">
          <a class="post-nav-link" href="/index.html">返回首页</a>
        </div>
        <div class="post-nav-item post-nav-next">
          {nextPost && <a href={nextPost.url}>下一篇文章（{nextPost.title}）</a>}
        </div>
      </nav>
    </div>
  </article>
  <script>
    import "../scripts/code-copy";
  </script>
</DocumentLayout>
