---
import Sidebar from "../components/Sidebar.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import DocumentLayout from "./DocumentLayout.astro";
import { site } from "../lib/site";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  skipHref?: string;
  skipText?: string;
  ogType?: "website" | "article";
  image?: string;
  sidebarProps?: Astro.ComponentProps<typeof Sidebar>;
  jsonLd?: Record<string, unknown>;
}

const {
  title = site.name,
  description = site.homeDescription,
  canonicalPath = Astro.url.pathname,
  skipHref = "#posts",
  skipText = "跳转到文章列表",
  ogType = "website",
  image = site.defaultCover,
  sidebarProps = {},
  jsonLd,
} = Astro.props;

---

<DocumentLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  ogType={ogType}
  image={image}
  jsonLd={jsonLd}
>
  <a class="skip-link" href={skipHref}>{skipText}</a>
  <ThemeToggle />
  <div class="layout">
    <div class="sidebar-transition-anchor" transition:name="site-sidebar" transition:animate="none">
      <Sidebar {...sidebarProps} />
    </div>
    <section class="content">
      <slot />
    </section>
  </div>

  <footer class="site-footer" transition:name="site-footer" transition:animate="none">
    <p>© 2026 — {site.footerOwner}</p>
  </footer>

</DocumentLayout>
