---
import BaseLayout from "../layouts/BaseLayout.astro";
import AboutStats from "../components/AboutStats.astro";
import AboutProfile from "../components/about/AboutProfile.astro";
import LinkList from "../components/about/LinkList.astro";
import MetricStrip from "../components/about/MetricStrip.astro";
import ProjectList from "../components/about/ProjectList.astro";
import ResumeSection from "../components/about/ResumeSection.astro";
import SkillList from "../components/about/SkillList.astro";
import Timeline from "../components/about/Timeline.astro";
import { getEntry } from "astro:content";
import { getNotes } from "../lib/notes";
import { getAllPosts } from "../lib/content/posts";
import { buildSiteStatistics } from "../lib/content/site-stats";
import { site } from "../lib/site";
import "../styles/about.css";

const about = await getEntry("about", "resume");
if (!about) {
  throw new Error("Missing src/content/about/resume.mdx");
}

const { Content } = await about.render();
const updated = about.data.updated?.toISOString().slice(0, 10);
const posts = await getAllPosts();
const notes = await getNotes();
const siteStats = buildSiteStatistics(posts, notes);
const mdxComponents = { LinkList, MetricStrip, ProjectList, ResumeSection, SkillList, Timeline };
---

<BaseLayout
  title={about.data.title}
  description={about.data.description}
  canonicalPath="/about.html"
  skipHref="#about-main"
  skipText="跳转到个人介绍"
  sidebarProps={{
    showAboutLink: false,
    extraLinks: [
      { href: "/index.html", label: "首页" },
      { href: "/notes.html", label: "随想" },
    ],
  }}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "AboutPage",
    name: `关于我 - ${site.name}`,
    url: `${site.url}/about.html`,
    isPartOf: site.url,
  }}
>
  <aside class="directory about-page" id="about-main">
    <h2 class="dir-title">{about.data.title}</h2>
    {updated && <p class="meta">更新：{updated}</p>}
    <AboutProfile
      headline={about.data.headline}
      location={about.data.location}
      availability={about.data.availability}
      links={about.data.links}
    />
    <div class="resume-content">
      <Content components={mdxComponents} />
    </div>
    {about.data.showSiteStats && <AboutStats {...siteStats} showWritingHistory={about.data.showWritingHistory} />}
  </aside>
</BaseLayout>
