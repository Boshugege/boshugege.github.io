---
import PostLayout from "../../layouts/PostLayout.astro";
import { render } from "astro:content";
import { getAllPosts, type PostSummary } from "../../lib/content/posts";
import { absoluteUrl, site } from "../../lib/site";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      previousPost: posts[index - 1],
      nextPost: posts[index + 1],
    },
  }));
}

const { post, previousPost, nextPost } = Astro.props as {
  post: PostSummary;
  previousPost?: PostSummary;
  nextPost?: PostSummary;
};
const rendered = await render(post.entry);
const Content = rendered?.Content;
---

<PostLayout
  title={post.title}
  description={post.excerpt}
  date={post.date}
  updated={post.updated}
  tags={post.tags}
  canonicalPath={post.canonical || `/${post.url}`}
  image={post.cover}
  imageAlt={post.coverAlt}
  contentClass={post.slug === "cg-final-path-tracing" ? "images-centered" : undefined}
  wordCount={post.reading.wordCount}
  readingMinutes={post.reading.readingMinutes}
  hasMath={post.features.hasMath}
  previousPost={previousPost && { title: previousPost.title, url: `/${previousPost.url}` }}
  nextPost={nextPost && { title: nextPost.title, url: `/${nextPost.url}` }}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.title,
    description: post.excerpt,
    datePublished: post.date,
    dateModified: post.updated || post.date,
    author: {
      "@type": "Person",
      name: "ParityNonconservation",
      url: absoluteUrl("/about.html"),
    },
    publisher: {
      "@type": "Organization",
      name: site.name,
      url: site.url,
      logo: {
        "@type": "ImageObject",
        url: absoluteUrl(site.defaultCover),
      },
    },
    keywords: post.tags,
    mainEntityOfPage: absoluteUrl(`/${post.url}`),
    url: post.canonical || absoluteUrl(`/${post.url}`),
    image: post.cover.startsWith("http") ? post.cover : absoluteUrl(post.cover),
  }}
>
  <Content />
</PostLayout>
