---
import PostLayout from "../../layouts/PostLayout.astro";
import { getAllPosts, type PostSummary } from "../../lib/content/posts";
import { absoluteUrl } from "../../lib/site";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      previousPost: posts[index - 1],
      nextPost: posts[index + 1],
    },
  }));
}

const { post, previousPost, nextPost } = Astro.props as {
  post: PostSummary;
  previousPost?: PostSummary;
  nextPost?: PostSummary;
};
const rendered = await post.entry.render();
const Content = rendered?.Content;
---

<PostLayout
  title={post.title}
  description={post.excerpt}
  date={post.date}
  tags={post.tags}
  canonicalPath={`/${post.url}`}
  image={post.cover}
  wordCount={post.reading.wordCount}
  readingMinutes={post.reading.readingMinutes}
  hasMath={post.features.hasMath}
  transitionKey={post.slug}
  previousPost={previousPost && { title: previousPost.title, url: `/${previousPost.url}` }}
  nextPost={nextPost && { title: nextPost.title, url: `/${nextPost.url}` }}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.title,
    datePublished: post.date,
    url: absoluteUrl(`/${post.url}`),
    image: post.cover.startsWith("http") ? post.cover : absoluteUrl(post.cover),
  }}
>
  <Content />
</PostLayout>
