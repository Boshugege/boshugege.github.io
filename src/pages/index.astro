---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getNotes } from "../lib/notes";
import { getAllPosts } from "../lib/content/posts";
import { absoluteUrl, site } from "../lib/site";

const posts = await getAllPosts();
const notes = await getNotes();
const latestNote = notes[0];
const tagCounts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.tags) tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
}
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
const activeTag = Astro.url.searchParams.get("tag") || "";
const activeTagIndex = tags.findIndex(([tag]) => tag === activeTag);
const tagsExpanded = activeTagIndex >= 5;
const visiblePosts = activeTag ? posts.filter((post) => post.tags.includes(activeTag)) : posts;

function getPostMeta(post: (typeof posts)[number]) {
  return [
    post.date,
    `约 ${post.reading.wordCount.toLocaleString("zh-CN")} 字`,
    `约 ${post.reading.readingMinutes} 分钟读完`,
    post.tags.length > 0 ? post.tags.join(" / ") : "",
  ].filter(Boolean);
}
---

<BaseLayout
  title={site.name}
  canonicalPath="/index.html"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: site.name,
    url: site.url,
    potentialAction: {
      "@type": "SearchAction",
      target: `${site.url}/index.html?q={q}`,
      "query-input": "required name=q",
    },
  }}
>
  <aside class="directory latest-note-panel" id="latest-note-preview">
    <p class="latest-note-title">最近随想</p>
    <p class="latest-note-text" id="latest-note-text">
      {latestNote ? `${latestNote.date} · ${latestNote.body.replace(/\s+/g, " ").slice(0, 120)}` : "暂无随想"}
    </p>
    <p class="latest-note-link"><a href="/notes.html">查看全部随想</a></p>
  </aside>

  <aside class="directory" id="posts">
    <h2 class="dir-title">文章目录</h2>
    <div class="dir-tools">
      <input class="search-input" type="search" placeholder="搜索全文（标题 / 摘要 / 正文）" aria-label="搜索文章" data-post-search />
      <nav class="tag-nav in-directory" aria-label="标签筛选">
        <a href="/index.html" class:list={["tag", "top", { active: !activeTag }]} data-tag="" aria-current={!activeTag ? "page" : undefined}>全部</a>
        <div class:list={["tags-list", { collapsed: !tagsExpanded }]} data-tag-list>
          {tags.map(([tag, count], index) => (
            <a
              href={`/index.html?tag=${encodeURIComponent(tag)}`}
              class:list={["tag", { visible: index < 5, active: tag === activeTag }]}
              data-tag={tag}
              aria-current={tag === activeTag ? "page" : undefined}
            >
              {tag} ({count})
            </a>
          ))}
        </div>
        {tags.length > 5 && (
          <button class="tag-toggle" type="button" aria-expanded={String(tagsExpanded)} data-tag-toggle data-collapsed-label={`展开全部标签 (${tags.length})`}>
            {tagsExpanded ? "收起标签" : `展开全部标签 (${tags.length})`}
          </button>
        )}
      </nav>
    </div>
    <div class="dir-list" data-post-list>
      {visiblePosts.map((post) => (
        <div class="dir-item">
          <a class="dir-item-title" href={`/${post.url}`} data-astro-prefetch>
            {post.title}
          </a>
          <span class="meta dir-item-meta">
            {getPostMeta(post).join(" · ")}
          </span>
        </div>
      ))}
    </div>
  </aside>
  <script>
    import "../scripts/home";
  </script>
</BaseLayout>
