{
  "name": "boshugege-github-io",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.6"
  },
  "scripts": {
    "dev": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro build && node scripts/publish-root.mjs",
    "build:dist": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "typecheck": "tsc -p tsconfig.client.json",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "verify": "npm run typecheck && npm test && npm run build:dist && node scripts/verify-build.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.0",
    "@astrojs/rss": "^4.0.12",
    "astro": "^5.9.4",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
